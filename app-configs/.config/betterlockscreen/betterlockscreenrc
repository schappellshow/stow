# betterlockscreen config — OpenMandriva palette, kept in sync with
# quickshell/common/Theme.qml. Sourced by ~/.local/bin/betterlockscreen.
# Cache regenerates automatically when the wallpaper changes (quickshell's
# common/Wallpaper.qml) — or manually: betterlockscreen -u <image>

# Only cache the effects the lock-screen wrapper actually uses
fx_list=(dim blur dimblur)
dim_level=40
blur_level=1

# One image per monitor (span_image=true would stretch across all three)
span_image=false
lock_timeout=300

font="Hack"
loginbox=232627cc
loginshadow=00000000
locktext="Type password to unlock..."
time_format="%I:%M %p"

ringcolor=2080bbff
insidecolor=00000000
separatorcolor=00000000
ringvercolor=40da76ff
insidevercolor=00000000
ringwrongcolor=cc2263ff
insidewrongcolor=cc226322
keyhlcolor=40a5daff
bshlcolor=cc2263ff
verifcolor=ffffffff
timecolor=ffffffff
datecolor=afb3bdff
greetercolor=afb3bdff
layoutcolor=afb3bdff
wrongcolor=cc2263ff
