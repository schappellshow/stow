#!/usr/bin/env bash
# Push dark/light mode to every channel apps use for the "system" theme:
#   gsettings  → read by xdg-desktop-portal-gtk, which answers Electron and
#                libadwaita apps (portal routing: .config/xdg-desktop-portal/)
#   kdeglobals → Qt/KDE apps (via plasma-apply-colorscheme)
#   xsettingsd + gtk settings.ini → running/starting GTK apps
# Files are created if missing, so this works on a freshly-stowed machine.
# Called by quickshell's SystemTheme service on every dark-mode change.
set -u

mode="${1:-dark}"
case "$mode" in
    dark)  scheme=prefer-dark;  gtk_theme=Breeze-Dark; kde_scheme=BreezeDark;  prefer_dark=true ;;
    light) scheme=prefer-light; gtk_theme=Breeze;      kde_scheme=BreezeLight; prefer_dark=false ;;
    *) echo "usage: system-theme-apply dark|light" >&2; exit 1 ;;
esac

command -v gsettings >/dev/null && {
    gsettings set org.gnome.desktop.interface color-scheme "$scheme" 2>/dev/null
    gsettings set org.gnome.desktop.interface gtk-theme "$gtk_theme" 2>/dev/null
}

command -v plasma-apply-colorscheme >/dev/null \
    && plasma-apply-colorscheme "$kde_scheme" >/dev/null 2>&1

# xsettingsd: edit the existing (often KDE-generated) config, or seed one
xs="$HOME/.config/xsettingsd/xsettingsd.conf"
if [ -f "$xs" ]; then
    if grep -q '^Net/ThemeName ' "$xs"; then
        sed -i "s|^Net/ThemeName .*|Net/ThemeName \"$gtk_theme\"|" "$xs"
    else
        printf 'Net/ThemeName "%s"\n' "$gtk_theme" >>"$xs"
    fi
else
    mkdir -p "${xs%/*}"
    cat >"$xs" <<EOF
Net/ThemeName "$gtk_theme"
Net/IconThemeName "breeze-dark"
Gtk/CursorThemeName "breeze_cursors"
Gtk/FontName "Noto Sans,  10"
EOF
fi
pkill -HUP -x xsettingsd 2>/dev/null

# gtk3/gtk4 settings.ini: same edit-or-seed approach
for v in gtk-3.0 gtk-4.0; do
    ini="$HOME/.config/$v/settings.ini"
    if [ -f "$ini" ]; then
        if grep -q '^gtk-theme-name=' "$ini"; then
            sed -i "s|^gtk-theme-name=.*|gtk-theme-name=$gtk_theme|" "$ini"
        else
            printf 'gtk-theme-name=%s\n' "$gtk_theme" >>"$ini"
        fi
        if grep -q '^gtk-application-prefer-dark-theme=' "$ini"; then
            sed -i "s|^gtk-application-prefer-dark-theme=.*|gtk-application-prefer-dark-theme=$prefer_dark|" "$ini"
        else
            printf 'gtk-application-prefer-dark-theme=%s\n' "$prefer_dark" >>"$ini"
        fi
    else
        mkdir -p "${ini%/*}"
        printf '[Settings]\ngtk-theme-name=%s\ngtk-application-prefer-dark-theme=%s\n' \
            "$gtk_theme" "$prefer_dark" >"$ini"
    fi
done

exit 0
