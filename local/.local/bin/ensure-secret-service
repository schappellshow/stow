#!/usr/bin/env bash
# Ensure org.freedesktop.secrets is served in this session. Apps that vault
# credentials (Mailspring, browsers, ...) refuse to store logins without it.
#
# ksecretd is KWallet's KF6 secrets daemon — the deliberate KDE exception on
# this setup. kwallet-pam starts it during PAM (`ksecretd --pam-login`),
# already unlocked with the login password, but at that point the session bus
# does not exist: it has no DBUS_SESSION_BUS_ADDRESS, registers no D-Bus name,
# and just waits on $PAM_KWALLET5_LOGIN for the session environment. Plasma
# completes the handoff by running pam_kwallet_init (plasma-kwallet-pam
# .service); an awesome session has to do that itself, which is step 1 below.
#
# Note that the stray PAM daemon also satisfies a pgrep-style "already
# running" guard while serving nothing, and nothing D-Bus-activates
# org.freedesktop.secrets (no matching .service file) — so always test bus
# name ownership, never the process table.
set -u

PAM_INIT=/usr/lib64/libexec/pam_kwallet_init

has_owner() {
    gdbus call --session --dest org.freedesktop.DBus \
        --object-path /org/freedesktop/DBus \
        --method org.freedesktop.DBus.NameHasOwner org.freedesktop.secrets \
        2>/dev/null | grep -q true
}

# Registration is async; poll rather than guessing a sleep
wait_for_owner() {
    local tries=${1:-20}
    while [ "$tries" -gt 0 ]; do
        has_owner && return 0
        sleep 0.5
        tries=$((tries - 1))
    done
    return 1
}

# Already served (re-run, or awesome restarted mid-session)
has_owner && exit 0

# 1. Preferred: hand the session environment to the PAM-started daemon. It
#    then reaches the bus with the wallet already unlocked — no password
#    prompt. pam_kwallet_init is `env | socat -u STDIN UNIX-CONNECT:$sock`,
#    so it needs the full session env and a live listener on the socket.
if [ -n "${PAM_KWALLET5_LOGIN:-}" ] && [ -S "${PAM_KWALLET5_LOGIN}" ] \
   && [ -x "$PAM_INIT" ]; then
    if "$PAM_INIT" 2>/dev/null && wait_for_owner 10; then
        exit 0
    fi
fi

# 2. Fallback: stale socket or dead PAM daemon (e.g. it was killed earlier in
#    the session). Start a plain instance; the wallet will ask for its
#    password the first time an app requests a secret.
pkill -x ksecretd 2>/dev/null
sleep 0.5
setsid /usr/bin/ksecretd >/dev/null 2>&1 </dev/null &

wait_for_owner 20 && exit 0

echo "ensure-secret-service: org.freedesktop.secrets never appeared" >&2
exit 1
