#!/usr/bin/env bash
# Ensure org.freedesktop.secrets is served in this session. Apps that vault
# credentials (Mailspring, browsers, ...) refuse to store logins without it.
#
# ksecretd is KWallet's KF6 secrets daemon — the deliberate KDE exception on
# this setup. The catch: kwallet-pam launches `ksecretd --pam-login` at PAM
# time, before the session bus exists, so that instance has no
# DBUS_SESSION_BUS_ADDRESS or XDG_RUNTIME_DIR and never registers any D-Bus
# name — yet its mere presence defeats a pgrep-style "already running" guard,
# leaving the session with no secret service at all. Nothing D-Bus-activates
# org.freedesktop.secrets either (no matching .service file), so it must be a
# live daemon on the session bus.
#
# Hence: check the bus, not the process table, and replace a stray instance
# with one started inside the session.
set -u

has_owner() {
    gdbus call --session --dest org.freedesktop.DBus \
        --object-path /org/freedesktop/DBus \
        --method org.freedesktop.DBus.NameHasOwner org.freedesktop.secrets \
        2>/dev/null | grep -q true
}

# Already served (e.g. re-running this script, or awesome restarted)
has_owner && exit 0

# Clear the bus-less PAM instance; the wallet files on disk are untouched
pkill -x ksecretd 2>/dev/null
sleep 0.5

setsid /usr/bin/ksecretd >/dev/null 2>&1 </dev/null &

# Registration is async; give it a few seconds before declaring failure
for _ in $(seq 20); do
    sleep 0.5
    has_owner && exit 0
done

echo "ensure-secret-service: org.freedesktop.secrets never appeared" >&2
exit 1
